{
  "name": "ai-pet-companion",
  "version": "1.0.0",
  "description": "AI智能桌宠 - 桌面情感陪伴产品",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "nodemon --exec electron .",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["AI", "pet", "companion", "desktop", "emotional"],
  "author": "AI Product Manager Intern",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-electron": "^0.1.12"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "build": {
    "appId": "com.aipet.companion",
    "productName": "AI智能桌宠",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icons/icon.icns"
    },
    "linux": {
      "target": "deb",
      "icon": "build/icons"
    }
  }
}